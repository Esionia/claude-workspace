# 素材分析配置
# 使用方式: 将此文件复制为 config.env 并填入你的配置

# ============ OpenAI API 配置 ============
# OpenAI API Key (用于GPT-4V图片分析)
# 可从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-api-key-here

# API 端点 (可选，默认使用官方API)
# 如果使用代理或国内API，修改此项
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============ FFmpeg 配置 (可选) ============
# 如果ffmpeg不在系统PATH中，可以指定完整路径
# FFMPEG_PATH=C:/path/to/ffmpeg.exe
