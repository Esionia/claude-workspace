# 语音克隆 + 数字人配置
# 使用方式: 将此文件复制为 config.env 并填入你的配置

# ============ 账号信息 ============
# 登录邮箱和密码（用于 token 失效时自动重新登录）
EMAIL=your_email@example.com
PASSWORD=your_password

# ============ 声音配置 ============
# 已训练好的声音音频 URL (永久有效)
# 可在软件中训练声音后，从数据库获取: aigc_human.db -> voice_models 表
VOICE_URL=https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/3044/audio/1772783478839_nahh8q.wav

# ============ 数字人配置 ============
# 数字人视频模板 URL (永久有效)
# 可在软件中上传数字人后，从日志或数据库获取
# 示例:
#   - 示例1-绿幕: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764939140639_f6tv14.mp4
#   - 示例2-夜间: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764939268635_hb1jfp.mp4
#   - 示例3-白天: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764939330553_1u3ywx.mp4
#   - 示例4-清新: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764940016951_uvmhdp.mp4
#   - 示例5-正式: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764940468772_x1tl4e.mp4
#   - 示例6-户外: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/2/video/1764940553356_kr5t7i.mp4
#   - 你上传的数字人1: https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/3044/video/1773933921981_uzbdvw.mp4
DIGITAL_HUMAN_URL=https://static-1251729840.cos.ap-guangzhou.myqcloud.com/digital_human/3044/video/1773933921981_uzbdvw.mp4
